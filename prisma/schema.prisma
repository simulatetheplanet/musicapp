generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SongSource {
  ARCHIVE
  PUBLIC
  SHARED
}

enum SongVisibility {
  PRIVATE
  PUBLIC
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MembershipPlan {
  FREE
  PLUS
}

enum AdPlacement {
  BANNER
  BETWEEN_SONGS
}

model User {
  id               String    @id @default(cuid())
  name             String?
  username         String?   @unique
  email            String    @unique
  emailVerified    DateTime?
  image            String?
  handle           String?   @unique
  bio              String?
  profileBannerUrl String?
  profileBannerFileType String?
  membershipPlan   MembershipPlan @default(FREE)
  plusStartedAt    DateTime?
  verification     VerificationRequest?
  lastFmConnection LastFmConnection?
  listeningActivities ListeningActivity[]
  adImpressions    AdImpression[]
  customEmojis     CustomEmoji[]
  songs            Song[]
  sentMessages     Message[]
  conversationUsers ConversationUser[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

model LastFmConnection {
  id             String   @id @default(cuid())
  userId         String   @unique
  username       String
  sessionKey     String?  @db.Text
  connectedAt    DateTime @default(now())
  lastSyncedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ListeningActivity {
  id              String   @id @default(cuid())
  userId          String
  songId          String?
  source          String
  title           String
  artist          String
  isNowPlaying    Boolean  @default(false)
  lastFmScrobbled Boolean  @default(false)
  startedAt       DateTime @default(now())
  endedAt         DateTime?

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  song Song? @relation(fields: [songId], references: [id], onDelete: SetNull)
}

model AdImpression {
  id        String      @id @default(cuid())
  userId    String
  placement  AdPlacement
  campaign  String
  shownAt   DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CustomEmoji {
  id         String   @id @default(cuid())
  ownerId    String
  name       String
  storageKey String
  publicUrl  String
  fileType   String
  createdAt  DateTime @default(now())

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model VerificationRequest {
  id          String             @id @default(cuid())
  userId      String             @unique
  status      VerificationStatus @default(PENDING)
  legalName   String
  publicName  String
  evidenceUrl String?
  reviewedAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Song {
  id            String         @id @default(cuid())
  ownerId       String
  title         String
  artist        String
  caption       String?
  storageKey    String
  publicUrl     String
  fileType      String
  sizeBytes     Int
  durationMs    Int?
  source        SongSource     @default(ARCHIVE)
  visibility    SongVisibility @default(PRIVATE)
  tags          SongTag[]
  messages      MessageSong[]
  comments      Comment[]
  likes         SongLike[]
  reposts       Repost[]
  listeningActivities ListeningActivity[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  songs     SongTag[]
  createdAt DateTime  @default(now())
}

model SongTag {
  songId String
  tagId  String

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([songId, tagId])
}

model Conversation {
  id        String             @id @default(cuid())
  name      String?
  isGroup   Boolean            @default(false)
  users     ConversationUser[]
  messages  Message[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model ConversationUser {
  conversationId String
  userId         String
  joinedAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  senderId       String
  body           String?
  songs          MessageSong[]
  reactions      Reaction[]
  createdAt      DateTime      @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model MessageSong {
  messageId String
  songId    String

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  song    Song    @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@id([messageId, songId])
}

model Reaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  value     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(cuid())
  songId    String
  userId    String
  body      String?
  mediaUrl  String?
  createdAt DateTime @default(now())

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)
}

model SongLike {
  songId    String
  userId    String
  createdAt DateTime @default(now())

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@id([songId, userId])
}

model Repost {
  songId    String
  userId    String
  createdAt DateTime @default(now())

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@id([songId, userId])
}

model ProductEvent {
  id         String   @id @default(cuid())
  userId     String
  name       String
  properties Json?
  createdAt  DateTime @default(now())
}
