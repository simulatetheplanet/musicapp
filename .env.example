# Database used by Prisma during local development.
DATABASE_URL="postgresql://musicapp:musicapp@localhost:5432/musicapp?schema=public"

# Redis used by BullMQ during local development.
REDIS_URL="redis://localhost:6379"

# Local app URL used by auth and email verification links.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-local-development-secret"

# Local provider selections. These are intentionally swappable later.
STORAGE_PROVIDER="local"
EMAIL_PROVIDER="local"
ANALYTICS_PROVIDER="local"

# Optional Last.fm integration. The app runs without these during local development.
LASTFM_API_KEY=""
LASTFM_SHARED_SECRET=""
